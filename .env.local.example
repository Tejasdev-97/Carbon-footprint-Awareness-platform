# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values.
# The app works fully offline without these - they are only needed for
# community features (pledge wall and leaderboard).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Note: The Gemini API key is stored ONLY in IndexedDB (via Settings page).
# Never put it here or in any environment variable.
